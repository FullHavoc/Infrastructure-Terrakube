# Backend configuration for Infrastructure-Terrakube workspace manager
# Copy to backend.hcl (gitignored) and fill in your values
#
# Token: Terrakube UI → Settings → Personal Access Tokens
# Set via env var: export TF_TOKEN_api_terrakube_rollet_family="<token>"

hostname     = "api.terrakube.rollet.family"
organization = "HomeInfrastructure"
workspaces {
  name = "Infrastructure-Terrakube"
}
